# ============================================================
#  mezmo-aura-pov — environment configuration
#  Copy to .env and fill in your values before running.
# ============================================================

# === LLM Provider (required — choose ONE) ================
OPENAI_API_KEY=sk-...your-openai-key-here...
# ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...

# Model to use. OpenAI default:
AURA_MODEL=gpt-4o
# For Anthropic swap to:
# AURA_MODEL=claude-sonnet-4-6
# and change LLM_PROVIDER below to "anthropic"
LLM_PROVIDER=openai

# === Aura ====================================================
AURA_PORT=3030
# Version/tag of Aura image (built locally by default)
AURA_IMAGE_TAG=latest

# === Observability UI Ports (host-mapped) ==================
FRONTEND_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
LOCUST_WEB_PORT=8089

# === MCP Services ============================================
MCP_PROMETHEUS_PORT=8082
MCP_DOCKER_PORT=8083

# === Stretch Goal: Open WebUI ================================
OPENWEBUI_PORT=8081

# === Internal (leave as-is unless you have port conflicts) ==
PROMETHEUS_ADDR=http://prometheus:9090
