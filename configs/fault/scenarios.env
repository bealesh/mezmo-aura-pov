# Fault scenario configuration
# Used by inject-*.sh scripts to identify the flagd JSON path and flag names.

# Path to the live flagd config inside the cloned otel-demo repo
FLAGD_JSON_PATH="otel-demo/src/flagd/demo.flagd.json"

# Scenario: failing service (payment + cart)
FAULT_FAIL_FLAGS="paymentFailure paymentUnreachable cartFailure"

# Scenario: latency injection (Kafka queue + slow image loads)
FAULT_LATENCY_FLAGS="kafkaQueueProblems imageSlowLoad"

# Scenario: error spike (payment at partial failure rate only)
FAULT_ERROR_FLAGS="paymentFailure"

# All flags — used by reset-demo.sh to turn everything off
ALL_FAULT_FLAGS="llmInaccurateResponse llmRateLimitError productCatalogFailure recommendationCacheFailure adManualGc adHighCpu adFailure kafkaQueueProblems cartFailure paymentFailure paymentUnreachable loadGeneratorFloodHomepage imageSlowLoad failedReadinessProbe emailMemoryLeak"
